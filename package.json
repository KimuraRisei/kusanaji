{
    "name": "kusanaji",
    "version": "1.0.0",
    "description": "Japanese text converter for Node.js — romaji (5 systems), hiragana, katakana, furigana with prepasses, mixed-language segmentation, and kanji fallback",
    "author": "Kimura Risei <kimura.risei@gmail.com>",
    "license": "BUSL-1.1",
    "homepage": "https://github.com/KimuraRisei/kusanaji#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KimuraRisei/kusanaji.git"
    },
    "bugs": {
        "url": "https://github.com/KimuraRisei/kusanaji/issues"
    },
    "main": "src/index.js",
    "exports": {
        ".": {
            "import": "./src/index.js",
            "default": "./src/index.js"
        },
        "./pipeline": {
            "import": "./src/pipeline/prepasses.js"
        },
        "./romaji": {
            "import": "./src/romaji/emit.js"
        },
        "./kana": {
            "import": "./src/kana/emit.js"
        },
        "./text": {
            "import": "./src/text/segment-mixed.js"
        },
        "./text/kanji-fallback": {
            "import": "./src/text/kanji-fallback.js"
        },
        "./text/unknown-fallback": {
            "import": "./src/text/unknown-fallback.js"
        },
        "./text/jp-punctuation": {
            "import": "./src/text/jp-punctuation.js"
        }
    },
    "files": [
        "src/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "node --test test/*.test.mjs",
        "lint": "echo \"Linter not yet configured\""
    },
    "keywords": [
        "japanese",
        "romaji",
        "hiragana",
        "katakana",
        "furigana",
        "converter",
        "nlp",
        "hepburn",
        "kunrei",
        "wapuro"
    ],
    "devDependencies": {
        "esbuild": "^0.28.0"
    }
}
