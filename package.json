{
    "name": "kusanaji",
    "version": "1.6.0",
    "description": "Powerful Japanese text processor for Node.js — romaji conversion, hiragana, katakana, furigana with prepasses, mixed-language segmentation, traditional to modern kanji conversion, unicode normalization and kanji fallback",
    "author": "Kimura Risei <kimura.risei@gmail.com>",
    "license": "BUSL-1.1",
    "homepage": "https://github.com/KimuraRisei/kusanaji#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KimuraRisei/kusanaji.git"
    },
    "bugs": {
        "url": "https://github.com/KimuraRisei/kusanaji/issues"
    },
    "main": "src/index.js",
    "exports": {
        ".":         { "import": "./src/index.js", "default": "./src/index.js" },
        "./pipeline":{ "import": "./src/pipeline/index.js" },
        "./romaji":  { "import": "./src/romaji/index.js" },
        "./kana":    { "import": "./src/kana/index.js" },
        "./text":    { "import": "./src/text/index.js" }
    },
    "files": [
        "src/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "node --test test/*.test.mjs",
        "lint": "echo \"Linter not yet configured\""
    },
    "keywords": [
        "japanese",
        "romaji",
        "hiragana",
        "katakana",
        "furigana",
        "converter",
        "nlp",
        "hepburn",
        "kunrei",
        "wapuro"
    ],
    "devDependencies": {
        "esbuild": "^0.28.0"
    }
}